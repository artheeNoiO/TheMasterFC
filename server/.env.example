# Local dev (SQLite) — ฟรี ไม่ต้องมี Supabase
DATABASE_URL="file:./dev.db"

PORT=3001
CLIENT_URL=http://localhost:5173

# หลาย origin คั่นด้วย comma (home server + Vercel)
# CORS_ORIGINS=https://www.thesockermanager.com,https://thesockermanager.com,http://localhost:5173

# Cron secret — ใส่ค่าสุ่มยาวๆ แล้วใช้กับ cron-job.org
CRON_SECRET=change-me-to-a-long-random-string

# --- Production (Supabase + Render) ---
# เปลี่ยน provider ใน prisma/schema.prisma เป็น postgresql แล้วใช้ connection string จาก Supabase
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
