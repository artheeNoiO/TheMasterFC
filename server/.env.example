# Local dev (SQLite) — ฟรี ไม่ต้องมี Supabase
DATABASE_URL="file:./dev.db"

PORT=3001
CLIENT_URL=http://localhost:5173

# หลาย origin คั่นด้วย comma (home server + Vercel)
# CORS_ORIGINS=https://www.themasterfc.com,https://themasterfc.com,http://localhost:5173

# Cron secret — ใส่ค่าสุ่มยาวๆ แล้วใช้กับ cron-job.org
CRON_SECRET=change-me-to-a-long-random-string

# --- Auth ---
# Game ID (Phase 1): POST /api/auth/register, /api/auth/login — token = signed+expiring HMAC (30 วัน)
# Dev (local only, blocked when NODE_ENV=production): POST /api/auth/dev-register
# Production OAuth: ตั้ง Supabase ด้านล่าง

# AUTH_TOKEN_SECRET — ใช้เซ็นและตรวจสอบ auth token (HMAC-SHA256)
# ต้องเป็นค่าสุ่มยาวๆ ที่ไม่ซ้ำใคร (เช่น `openssl rand -hex 32`) และเก็บเป็นความลับ
# ถ้าไม่ตั้งค่านี้เมื่อ NODE_ENV=production เซิร์ฟเวอร์จะไม่สตาร์ท (fail loudly by design)
AUTH_TOKEN_SECRET=change-me-to-a-long-random-secret-before-deploying-to-production

# --- Online Phase 1 ---
# GAME_PROVISION_SECRET — shared secret ระหว่าง Cloudflare Pages Function กับ game API
# GAME_PROVISION_SECRET=change-me-long-random
# ONLINE_BETA_FREE=1 — ข้ามเงื่อนไข 50M ตอน unlock-online (Test Beta)
# ALLOW_MANUAL_TICK=1 — เปิด POST /leagues/:id/advance-day บน production (dev tool)
# และบังคับให้ตั้ง AUTH_TOKEN_SECRET
# NODE_ENV=production
# เปลี่ยน provider ใน prisma/schema.prisma เป็น postgresql แล้วใช้ connection string จาก Supabase
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
