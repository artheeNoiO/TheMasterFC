# คัดลอกเป็น server/.env แล้วแก้ค่าตามเครื่อง
# copy server\.env.home-server.example server\.env

# SQLite ในเครื่อง — backup ไฟล์ server/dev.db เป็นประจำ
DATABASE_URL="file:./dev.db"

PORT=3001

# หน้าเกมบน Vercel (คั่นหลาย domain ด้วย comma)
CORS_ORIGINS=https://www.themasterfc.com,https://themasterfc.com,http://localhost:5173

# URL หลัก (ใช้กับ redirect / เอกสาร — ไม่บังคับถ้ามี CORS_ORIGINS แล้ว)
CLIENT_URL=https://www.themasterfc.com

# สุ่มค่ายาวๆ — ใช้กับ Run-Game-Cron.bat และ Task Scheduler
CRON_SECRET=เปลี่ยนเป็นค่าสุ่ม-yours-32chars-minimum

# --- Auth (เลือก 1 แบบ) ---

# แบบ A: Dev auth (ทดสอบเร็ว ไม่ต้อง Supabase) — ปล่อย 2 บรรทัดล่างว่างไว้

# แบบ B: Supabase Free (แนะนำถ้าเปิดให้คนจริงเล่น)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stake League tick ใน process (ทุก 30 วิ) — ปิดได้ถ้าใช้ Task Scheduler อย่างเดียว
# STAKE_TICK_DISABLED=0
