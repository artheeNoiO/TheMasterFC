generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id
  email            String    @unique
  displayName      String?
  playMode         String    @default("sandbox")
  onlineUnlocked   Boolean   @default(false)
  onlineUnlockedAt DateTime?
  createdAt        DateTime  @default(now())
  club             Club?
}

model LeagueShard {
  id             String   @id @default(cuid())
  name           String
  division       Int      @default(1)
  seasonNumber   Int      @default(1)
  dayNumber      Int      @default(1)
  isFull         Boolean  @default(false)
  legendLeagueId String?
  clubs          Club[]
  matches        Match[]
  createdAt      DateTime @default(now())
}

model Club {
  id             String      @id @default(cuid())
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id])
  shardId        String
  shard          LeagueShard @relation(fields: [shardId], references: [id])
  name           String
  shortCode      String
  logoIndex      Int         @default(0)
  primaryColor   String
  secondaryColor String      @default("#f2f0e6")
  shirtColor     String?
  shortsColor    String?
  budget         Int         @default(10000000)
  tier           Int         @default(-3)
  formation      String      @default("4-4-2")
  chemistry      Int         @default(50)
  isBot          Boolean     @default(false)
  managerJson    String?
  autoMode       Boolean     @default(true)
  lineupJson     String?
  gameStateJson  String?
  players        Player[]
  standing       Standing?
  homeMatches    Match[]     @relation("HomeClub")
  awayMatches    Match[]     @relation("AwayClub")
}

model Standing {
  id     String @id @default(cuid())
  clubId String @unique
  club   Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  played Int    @default(0)
  w      Int    @default(0)
  d      Int    @default(0)
  l      Int    @default(0)
  gf     Int    @default(0)
  ga     Int    @default(0)
  pts    Int    @default(0)
}

model Player {
  id              String @id
  clubId          String
  club            Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  name            String
  position        String
  age             Int
  attrs           String
  attack          Int
  defense         Int
  rating          Int
  potential       Int
  value           Int
  wage            Int
  morale          Int
  stamina         Int
  injuryDays      Int    @default(0)
  careerGoals     Int    @default(0)
  careerApps      Int    @default(0)
  role            String @default("balanced")
  contractEndsDay Int?
  legendId          String?   @unique
  isLegend          Boolean   @default(false)
  homeClubId        String?
  legendLeagueId    String?
  ownerLastSeenDay  Int?
}

model Match {
  id         String      @id @default(cuid())
  shardId    String
  shard      LeagueShard @relation(fields: [shardId], references: [id], onDelete: Cascade)
  dayNumber  Int
  homeClubId String
  awayClubId String
  homeClub   Club        @relation("HomeClub", fields: [homeClubId], references: [id])
  awayClub   Club        @relation("AwayClub", fields: [awayClubId], references: [id])
  played     Boolean     @default(false)
  homeGoals  Int?
  awayGoals  Int?

  @@index([shardId, dayNumber])
}

model StakeLeague {
  id           String       @id @default(cuid())
  name         String       @default("Stake League")
  status       String       @default("recruiting") // recruiting | running | finished
  entryFee     Int          @default(100000000)
  valueCap     Int          @default(500000000)
  maxTeams     Int          @default(16)
  roundMinutes Int          @default(10)
  totalRounds  Int          @default(15)
  currentRound Int          @default(0)
  nextRoundAt  DateTime?
  prizePool    Int          @default(0)
  createdAt    DateTime     @default(now())
  startedAt    DateTime?
  finishedAt   DateTime?
  entries      StakeEntry[]
  matches      StakeMatch[]
}

model StakeEntry {
  id           String      @id @default(cuid())
  leagueId     String
  league       StakeLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  clubId       String?
  userId       String?
  name         String
  shortCode    String
  primaryColor String      @default("#5a9bd5")
  isBot        Boolean     @default(false)
  managerJson  String?
  squadJson    String // squad snapshot ตอนสมัคร (engine format)
  lineupJson   String?
  formation    String      @default("4-4-2")
  autoMode     Boolean     @default(true)
  squadValue   Int         @default(0)
  played       Int         @default(0)
  w            Int         @default(0)
  d            Int         @default(0)
  l            Int         @default(0)
  gf           Int         @default(0)
  ga           Int         @default(0)
  pts          Int         @default(0)
  prize        Int         @default(0)
  finalPos     Int?
  createdAt    DateTime    @default(now())

  @@index([leagueId])
}

model StakeMatch {
  id          String      @id @default(cuid())
  leagueId    String
  league      StakeLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  round       Int
  homeEntryId String
  awayEntryId String
  played      Boolean     @default(false)
  homeGoals   Int?
  awayGoals   Int?

  @@index([leagueId, round])
}
